<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Stable Money — AI Avatar Agent</title>
<style>
 :root {
 --cream:#FBF7F0; --blue:#4A90D9; --blue-dark:#2C5F8A;
 --blue-light:#EBF4FF; --gold:#C9962A; --green:#27AE60;
 --red:#E74C3C; --text:#1A1A2E; --muted:#7A8099;
 --radius:16px; --shadow:0 8px 32px rgba(74,144,217,0.12);
 }
 *{box-sizing:border-box;margin:0;padding:0}
 body{font-family:'Segoe UI',system-ui,sans-serif;background:var(--cream);color:var(--text);min-height:100vh}

 header{background:#fff;border-bottom:1px solid #E8EDF5;padding:14px 24px;display:flex;align-items:center;gap:12px;box-shadow:0 2px 8px rgba(0,0,0,0.04)}
 .logo{width:36px;height:36px;background:linear-gradient(135deg,var(--blue),var(--blue-dark));border-radius:10px;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:16px}
 header h1{font-size:18px;font-weight:700}
 header span{font-size:13px;color:var(--muted);margin-left:4px}
 .dot{margin-left:auto;width:10px;height:10px;border-radius:50%;background:#ccc;transition:background .3s}
 .dot.ready{background:var(--green);box-shadow:0 0 6px var(--green)}
 .dot.active{background:var(--blue);box-shadow:0 0 8px var(--blue);animation:pulse 1s infinite}
 .dot.speaking{background:var(--gold);box-shadow:0 0 8px var(--gold);animation:pulse .6s infinite}
 @keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}

 .main{display:flex;gap:20px;padding:20px;max-width:1100px;margin:0 auto}
 .left{flex:1;display:flex;flex-direction:column;gap:16px}
 .right{width:320px;display:flex;flex-direction:column;gap:16px}

 .card{background:#fff;border-radius:var(--radius);padding:20px;box-shadow:var(--shadow);border:1px solid #EEF2F8}
 .card-title{font-size:12px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:14px;display:flex;align-items:center;gap:6px}

 /* Avatar */
 .avatar-wrap{position:relative;background:linear-gradient(160deg,#EBF4FF,#D6EAFF);border-radius:var(--radius);overflow:hidden;aspect-ratio:4/3;display:flex;align-items:center;justify-content:center}
 #avatar-video{width:100%;height:100%;object-fit:cover;border-radius:var(--radius);display:none}
 .av-placeholder{display:flex;flex-direction:column;align-items:center;gap:12px}
 /* ── IMMERSIVE AVATAR ── */
 .avatar-wrap{background:linear-gradient(180deg,#1a1a2e 0%,#16213e 100%) !important;border-radius:20px !important;aspect-ratio:3/4 !important;position:relative;overflow:hidden;}
 .av-face{position:absolute;inset:0;width:100%;height:100%;border-radius:0;border:none;box-shadow:none;background:transparent;}
 .av-face img{width:100%;height:100%;object-fit:cover;object-position:center 10%;display:block;filter:brightness(1.05);}
 /* gradient fade at bottom */
 .av-face::before{content:'';position:absolute;bottom:0;left:0;right:0;height:35%;background:linear-gradient(transparent,rgba(26,26,46,0.95));z-index:2;}
 /* mouth animation bar */
 .mouth-overlay{position:absolute;bottom:22%;left:50%;transform:translateX(-50%);width:18%;z-index:3;display:flex;gap:3px;align-items:flex-end;height:20px;}
 .mouth-bar{flex:1;background:rgba(255,255,255,0.9);border-radius:4px;height:4px;transform-origin:bottom;}
 .mouth-bar{transition:height .05s ease;}
 /* speaking glow */
 .av-face.talking::after{content:'';position:absolute;inset:0;border-radius:20px;box-shadow:inset 0 0 40px rgba(74,144,217,0.25);z-index:1;animation:glow-pulse .6s infinite alternate;}
 @keyframes glow-pulse{0%{box-shadow:inset 0 0 20px rgba(74,144,217,0.1)}100%{box-shadow:inset 0 0 60px rgba(74,144,217,0.35)}}
 /* name tag */
 .av-label{position:absolute;bottom:8%;left:50%;transform:translateX(-50%);z-index:4;background:rgba(255,255,255,0.12);backdrop-filter:blur(8px);color:#fff;font-size:13px;font-weight:600;padding:6px 16px;border-radius:20px;border:1px solid rgba(255,255,255,0.2);white-space:nowrap;}
 /* hide old placeholder wrapper */
 .av-placeholder{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;padding-bottom:12%;}

 /* waveform canvas */
 #waveform{width:100%;height:48px;border-radius:8px;background:#F0F6FF;display:block}

 /* mic btn */
 .mic-wrap{text-align:center}
 #mic-btn{width:76px;height:76px;border-radius:50%;border:none;background:linear-gradient(135deg,var(--blue),var(--blue-dark));color:#fff;font-size:30px;cursor:pointer;box-shadow:0 6px 20px rgba(74,144,217,.4);transition:transform .2s;display:flex;align-items:center;justify-content:center;margin:0 auto 10px}
 #mic-btn:hover{transform:scale(1.05)}
 #mic-btn.active{background:linear-gradient(135deg,var(--red),#C0392B);animation:mic-p 1s infinite;box-shadow:0 6px 20px rgba(231,76,60,.4)}
 @keyframes mic-p{0%,100%{transform:scale(1)}50%{transform:scale(1.08)}}
 #mic-label{font-size:13px;color:var(--muted)}

 #status-bar{text-align:center;font-size:13px;color:var(--muted);padding:8px 12px;border-radius:8px;background:#F5F7FB;font-weight:500;margin-top:10px}
 #status-bar.ok{color:var(--green);background:#F0FFF4}
 #status-bar.active{color:var(--blue);background:var(--blue-light)}
 #status-bar.speaking{color:var(--gold);background:#FFF8E7}
 #status-bar.error{color:var(--red);background:#FFF0EE}

 /* transcript */
 #transcript{min-height:50px;background:var(--blue-light);border-radius:10px;padding:12px 14px;font-size:14px;line-height:1.5;border:1px dashed #B8D4F0;color:var(--muted);font-style:italic}
 #transcript.has-text{color:var(--text);font-style:normal}

 /* response */
 #response{min-height:80px;max-height:180px;overflow-y:auto;font-size:14px;line-height:1.7}
 .cursor{display:inline-block;width:2px;height:15px;background:var(--blue);margin-left:2px;animation:blink .7s infinite;vertical-align:middle}
 @keyframes blink{0%,100%{opacity:1}50%{opacity:0}}

 /* quick prompts */
 .qps{display:flex;flex-wrap:wrap;gap:8px}
 .qp{background:var(--blue-light);color:var(--blue-dark);border:1px solid #C5DCF5;border-radius:20px;padding:6px 14px;font-size:12px;cursor:pointer;transition:background .2s}
 .qp:hover{background:#D0E8FF}

 /* log */
 .log{display:flex;flex-direction:column;gap:10px;max-height:260px;overflow-y:auto}
 .li{display:flex;gap:8px;align-items:flex-start}
 .li .bub{padding:8px 12px;border-radius:12px;font-size:13px;line-height:1.5;max-width:100%}
 .li.user .bub{background:var(--blue-light);color:var(--blue-dark);border-radius:12px 12px 4px 12px}
 .li.agent .bub{background:#F0FFF4;color:#1A5C2E;border-radius:12px 12px 12px 4px}
 .la{width:26px;height:26px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:12px}
 .li.user .la{background:var(--blue);color:#fff}
 .li.agent .la{background:var(--green);color:#fff}

 /* server config */
 .cfg input{border:1px solid #DDE3EE;border-radius:8px;padding:8px 12px;font-size:13px;color:var(--text);background:#FAFBFD;width:100%;outline:none;transition:border .2s}
 .cfg input:focus{border-color:var(--blue);background:#fff}
 .cfg label{font-size:12px;font-weight:600;color:var(--muted);display:block;margin-bottom:4px;margin-top:10px}
 #connect-btn{background:linear-gradient(135deg,var(--blue),var(--blue-dark));color:#fff;border:none;border-radius:10px;padding:10px;font-size:14px;font-weight:600;cursor:pointer;width:100%;margin-top:12px;transition:opacity .2s}
 #connect-btn:hover{opacity:.9}

 /* upload */
 .uploader{border:2px dashed #B8D4F0;border-radius:12px;padding:16px;text-align:center;cursor:pointer;transition:border-color .2s,background .2s}
 .uploader:hover{border-color:var(--blue);background:var(--blue-light)}
 .uploader input{display:none}
 .uploader p{font-size:12px;color:var(--muted);margin-top:4px}
 #photo-prev{width:70px;height:70px;border-radius:50%;object-fit:cover;display:none;margin:0 auto 8px;border:3px solid var(--blue)}

 ::-webkit-scrollbar{width:4px}
 ::-webkit-scrollbar-thumb{background:#C5D5E8;border-radius:4px}
</style>
</head>
<body>

<header>
 <div class="logo">S</div>
 <h1>Stable Money <span>— AI Avatar Agent</span></h1>
 <div class="dot" id="dot"></div>
</header>

<div class="main">
 <div class="left">

 <!-- Avatar -->
 <div class="card">
 <div class="card-title">🎭 Avatar</div>
 <div class="avatar-wrap">
 <video id="avatar-video" autoplay playsinline muted></video>
 <div class="av-placeholder" id="av-ph" style="position:absolute;inset:0;display:block;">
 <div class="av-face" id="av-face">
 <img src="/avatar.jpg" alt="Avatar"/>
 <div class="mouth-overlay">
   <div class="mouth-bar"></div>
   <div class="mouth-bar"></div>
   <div class="mouth-bar"></div>
   <div class="mouth-bar"></div>
   <div class="mouth-bar"></div>
 </div>
 </div>
 <div class="av-label" id="av-label">Ready to talk</div>
 <div class="av-label" id="av-label">Waiting for server…</div>
 </div>
 </div>
 </div>

 <!-- Waveform -->
 <div class="card" style="padding:14px">
 <canvas id="waveform"></canvas>
 </div>

 <!-- Mic -->
 <div class="card mic-wrap">
 <button id="mic-btn" onclick="toggleMic()">🎙️</button>
 <div id="mic-label">Tap to speak</div>
 <div id="status-bar">Connect to your server first…</div>
 </div>

 <!-- Transcript -->
 <div class="card">
 <div class="card-title">📝 You said</div>
 <div id="transcript">Your speech will appear here…</div>
 </div>

 <!-- Response -->
 <div class="card">
 <div class="card-title">🤖 Agent</div>
 <div id="response"><span style="color:var(--muted);font-style:italic">Response streams here…</span></div>
 </div>

 <!-- Quick prompts -->
 <div class="card">
 <div class="card-title">⚡ Quick Questions</div>
 <div class="qps">
 <div class="qp" onclick="send(this.innerText)">What is Stable Money?</div>
 <div class="qp" onclick="send(this.innerText)">How safe are FDs?</div>
 <div class="qp" onclick="send(this.innerText)">What returns can I expect?</div>
 <div class="qp" onclick="send(this.innerText)">How is this different from a bank?</div>
 <div class="qp" onclick="send(this.innerText)">Tell me about Sukoon</div>
 <div class="qp" onclick="send(this.innerText)">How do I start investing?</div>
 </div>
 </div>

 </div>

 <div class="right">

 <!-- Server config -->
 <div class="card cfg">
 <div class="card-title">⚙️ Server Config</div>
 <label>SERVER URL</label>
 <input id="server-url" value="ws://localhost:8000/ws/talk" placeholder="ws://your-server:8000/ws/talk"/>
 <label>ANTHROPIC API KEY</label>
 <input id="anthropic-key" type="password" placeholder="sk-ant-…"/>
 <button id="connect-btn" onclick="connectServer()">🔌 Connect</button>
 </div>

 <!-- Upload photo -->
 <div class="card">
 <div class="card-title">📸 Your Photo</div>
 <label class="uploader" for="photo-inp">
 <input type="file" id="photo-inp" accept="image/*" onchange="uploadPhoto(event)"/>
 <img id="photo-prev" src="" alt=""/>
 <div style="font-size:26px">📷</div>
 <p>Upload front-facing photo<br/>to activate your avatar</p>
 </label>
 </div>

 <!-- Upload voice -->
 <div class="card">
 <div class="card-title">🎤 Voice Clone</div>
 <label class="uploader" for="voice-inp">
 <input type="file" id="voice-inp" accept="audio/*" onchange="uploadVoice(event)"/>
 <div style="font-size:26px">🎙️</div>
 <p>Upload 6–30s audio sample<br/>to clone your voice</p>
 </label>
 </div>

 <!-- Conversation log -->
 <div class="card">
 <div class="card-title">💬 Conversation</div>
 <div class="log" id="log"></div>
 </div>

 </div>
</div>

<script>
// ── EYE BLINK ──
function startBlinking() {
 function blink() {
 document.getElementById('av-face').classList.add('blinking');
 setTimeout(() => document.getElementById('av-face').classList.remove('blinking'), 200);
 setTimeout(blink, 2000 + Math.random() * 3000);
 }
 setTimeout(blink, 1000);
}
startBlinking();

// ── STATE ──
const S = {
 ws: null, ready: false, listening: false, speaking: false,
 recognition: null, transcript: '',
 history: [],  // for display only — server handles Claude context
 audioCtx: null, analyser: null, animId: null
};

const SYSTEM_PROMPT = `You are a friendly financial advisor for Stable Money — India's leading fixed-income investment platform. 
Stable Money offers FDs from 25+ NBFCs and small finance banks with 8–9.5% returns, plus Sukoon — a no-lock-in idle money product earning 7–8%.
Be warm, concise (2–4 sentences), and end with a light call-to-action. Speak like a trusted friend who knows finance.`;

// ── SERVER CONNECTION ──
function connectServer() {
 const url = document.getElementById('server-url').value.trim();
 const aKey = document.getElementById('anthropic-key').value.trim();
 if (!url) { setStatus('Enter server URL', 'error'); return; }
 // API key temporarily disabled for testing

 setStatus('🔌 Connecting…', 'active');
 try {
 S.ws = new WebSocket(url);

 S.ws.onopen = () => {
 S.ws.send(JSON.stringify({ type: 'config', anthropic_key: aKey, system_prompt: SYSTEM_PROMPT }));
 // Pre-request mic permission so it's ready when user taps
 navigator.mediaDevices.getUserMedia({ audio: true })
   .then(s => { s.getTracks().forEach(t => t.stop()); console.log('Mic ready'); })
   .catch(e => console.warn('Mic permission:', e));
 S.ready = true;
 setStatus('✅ Connected! Tap mic to speak', 'ok');
 document.getElementById('dot').className = 'dot ready';
 document.getElementById('av-label').textContent = 'Ready to talk';
 document.getElementById('connect-btn').textContent = '✅ Connected';
 };

 S.ws.onmessage = e => handleServerMsg(JSON.parse(e.data));

 S.ws.onerror = () => { setStatus('❌ Connection failed', 'error'); S.ready = false; };
 S.ws.onclose = () => { setStatus('⚠️ Disconnected', 'error'); S.ready = false; document.getElementById('dot').className = 'dot'; };

 } catch(err) { setStatus('❌ ' + err.message, 'error'); }
}

function handleServerMsg(msg) {
 switch(msg.type) {

 case 'status':
 const labels = { synthesizing:'🔊 Synthesizing voice…', animating:'🎭 Animating avatar…' };
 setStatus(labels[msg.msg] || msg.msg, 'active');
 break;

 case 'text_chunk':
 // streaming Claude response
 appendResponse(msg.text);
 break;

 case 'audio':
 playAudio(msg.data, msg.format);
 break;

 case 'video':
 playVideo(msg.data);
 break;

 case 'done':
 if (_respText.trim()) addLog('agent', _respText);
 break;

 case 'error':
 setStatus('❌ ' + msg.msg, 'error');
 S.speaking = false;
 break;
 }
}

// ── AUDIO PLAYBACK + WAVEFORM ──
function playAudio(b64, fmt) {
 const bytes = Uint8Array.from(atob(b64), c => c.charCodeAt(0));
 const blob = new Blob([bytes], { type: `audio/${fmt}` });
 const url  = URL.createObjectURL(blob);
 const audio = new Audio(url);

 // waveform
 if (!S.audioCtx) S.audioCtx = new AudioContext();
 const src = S.audioCtx.createMediaElementSource(audio);
 S.analyser = S.audioCtx.createAnalyser();
 S.analyser.fftSize = 256;
 src.connect(S.analyser);
 S.analyser.connect(S.audioCtx.destination);

 audio.onplay = () => {
 S.speaking = true;
 setStatus('🔊 Speaking…', 'speaking');
 document.getElementById('dot').className = 'dot speaking';
 document.getElementById('av-face').classList.add('talking');
 drawWaveform();
 driveMouth();
 };
 audio.onended = () => {
 cancelAnimationFrame(S.animId);
 cancelAnimationFrame(S.mouthId);
 clearWaveform();
 stopMouthAnim();
 S.speaking = false;
 setStatus('✅ Ready! Tap mic to speak', 'ok');
 document.getElementById('dot').className = 'dot ready';
 document.getElementById('av-face').classList.remove('talking');
 document.getElementById('mic-btn').disabled = false;
 };
 audio.play().catch(console.error);
}

function driveMouth() {
 const bars = document.querySelectorAll('.mouth-bar');
 if (!S.analyser || !bars.length) return;
 const buf = new Uint8Array(S.analyser.frequencyBinCount);
 function frame() {
   S.mouthId = requestAnimationFrame(frame);
   S.analyser.getByteFrequencyData(buf);
   // get average of low-mid frequencies (speech range)
   const lo = Math.floor(buf.length * 0.02);
   const hi = Math.floor(buf.length * 0.15);
   let sum = 0;
   for (let i = lo; i < hi; i++) sum += buf[i];
   const avg = sum / (hi - lo);
   const scale = avg / 255;
   const heights = [
     8 + scale * 14,
     10 + scale * 20,
     12 + scale * 26,
     10 + scale * 20,
     8 + scale * 14
   ];
   bars.forEach((b, i) => b.style.height = heights[i] + 'px');
 }
 frame();
}

function stopMouthAnim() {
 const bars = document.querySelectorAll('.mouth-bar');
 bars.forEach(b => b.style.height = '3px');
}

function drawWaveform() {
 const canvas = document.getElementById('waveform');
 const ctx = canvas.getContext('2d');
 const buf = new Uint8Array(S.analyser.frequencyBinCount);

 function frame() {
 S.animId = requestAnimationFrame(frame);
 S.analyser.getByteFrequencyData(buf);
 ctx.clearRect(0, 0, canvas.width, canvas.height);
 const bw = canvas.width / buf.length;
 buf.forEach((v, i) => {
 const h = (v / 255) * canvas.height;
 const hue = 210 + (v / 255) * 30;
 ctx.fillStyle = `hsla(${hue},70%,60%,0.8)`;
 ctx.fillRect(i * bw, canvas.height - h, bw - 1, h);
 });
 }
 frame();
}

function clearWaveform() {
 const canvas = document.getElementById('waveform');
 canvas.getContext('2d').clearRect(0, 0, canvas.width, canvas.height);
}

// ── VIDEO PLAYBACK ──
function playVideo(b64) {
 const bytes = Uint8Array.from(atob(b64), c => c.charCodeAt(0));
 const blob = new Blob([bytes], { type: 'video/mp4' });
 const url  = URL.createObjectURL(blob);
 const vid  = document.getElementById('avatar-video');
 vid.src = url;
 vid.style.display = 'block';
 document.getElementById('av-ph').style.display = 'none';
 vid.play().catch(console.error);
 vid.onended = () => {
 vid.style.display = 'none';
 document.getElementById('av-ph').style.display = 'flex';
 };
}

// ── MIC ──
function toggleMic() {
 if (!S.ready) { setStatus('⚠️ Connect to server first', 'error'); return; }
 if (S.speaking) return;
 S.listening ? stopMic() : startMic();
}

function startMic() {
 const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
 if (!SR) { setStatus('❌ Browser STT not supported — use Chrome/Edge', 'error'); return; }

 S.recognition = new SR();
 S.recognition.continuous = false;
 S.recognition.interimResults = true;
 S.recognition.lang = 'en-IN';

 S.recognition.onstart = () => {
 S.listening = true;
 document.getElementById('mic-btn').classList.add('active');
 document.getElementById('mic-btn').textContent = '🔴';
 document.getElementById('mic-label').textContent = 'Listening…';
 setStatus('🎙️ Listening…', 'active');
 document.getElementById('dot').className = 'dot active';
 setTranscript('', false);
 };

 S.recognition.onresult = e => {
 let interim = '', final = '';
 for (let i = e.resultIndex; i < e.results.length; i++) {
 e.results[i].isFinal
 ? (final += e.results[i][0].transcript)
 : (interim += e.results[i][0].transcript);
 }
 setTranscript(final || interim, !!final);
 if (final) S.transcript = final;
 };

 S.recognition.onend = () => {
 stopMic();
 if (S.transcript) send(S.transcript);
 };

 S.recognition.onerror = err => {
 setStatus('❌ Mic: ' + err.error, 'error');
 stopMic();
 };

 S.recognition.start();
}

function stopMic() {
 S.listening = false;
 document.getElementById('mic-btn').classList.remove('active');
 document.getElementById('mic-btn').textContent = '🎙️';
 document.getElementById('mic-label').textContent = 'Tap to speak';
 if (S.recognition) { try { S.recognition.stop(); } catch {} }
}

// ── SEND TO SERVER ──
function send(text) {
 if (!S.ready || S.speaking || S.listening) return;
 if (!text.trim()) return;

 resetResponse();
 setTranscript(text, true);
 addLog('user', text);
 S.transcript = '';
 S.speaking = true;

 document.getElementById('response').innerHTML = '<span class="cursor"></span>';
 document.getElementById('mic-btn').disabled = true;
 setStatus('🧠 Thinking…', 'active');

 S.ws.send(JSON.stringify({ type: 'speak', text, history: S.history }));
 S.history.push({ role: 'user', content: text });
}

let _respText = '';

function resetResponse() {
  _respText = '';
  document.getElementById('response').innerHTML =
    '<span style="color:var(--muted);font-style:italic">Response streams here…</span>';
}
function appendResponse(chunk) {
 _respText = chunk;
 document.getElementById('response').innerHTML = _respText + '<span class="cursor"></span>';
 if (S.history.length && S.history[S.history.length-1].role === 'user') {
 S.history.push({ role: 'assistant', content: _respText });
 } else if (S.history.length && S.history[S.history.length-1].role === 'assistant') {
 S.history[S.history.length-1].content = _respText;
 }
}

// ── UPLOADS ──
async function uploadPhoto(e) {
 const file = e.target.files[0]; if (!file) return;
 const prev = document.getElementById('photo-prev');
 prev.src = URL.createObjectURL(file);
 prev.style.display = 'block';

 const serverBase = document.getElementById('server-url').value.replace('ws','http').replace('/ws/talk','');
 const fd = new FormData(); fd.append('file', file);
 const res = await fetch(`${serverBase}/upload/avatar`, { method:'POST', body:fd });
 const d  = await res.json();
 setStatus(d.status === 'ok' ? '✅ Avatar photo uploaded!' : '❌ Upload failed', d.status === 'ok' ? 'ok':'error');
}

async function uploadVoice(e) {
 const file = e.target.files[0]; if (!file) return;
 const serverBase = document.getElementById('server-url').value.replace('ws','http').replace('/ws/talk','');
 const fd = new FormData(); fd.append('file', file);
 const res = await fetch(`${serverBase}/upload/voice`, { method:'POST', body:fd });
 const d  = await res.json();
 setStatus(d.status === 'ok' ? '✅ Voice sample uploaded — cloning active!' : '❌ Upload failed', d.status === 'ok' ? 'ok':'error');
}

// ── HELPERS ──
function setTranscript(t, isFinal) {
 const el = document.getElementById('transcript');
 if (!t) { el.textContent = 'Your speech will appear here…'; el.classList.remove('has-text'); return; }
 el.classList.add('has-text');
 el.textContent = t + (isFinal ? '' : ' …');
}

function setStatus(msg, type='') {
 const el = document.getElementById('status-bar');
 el.textContent = msg;
 el.className = '';
 if (type) el.classList.add(type);
}

function addLog(role, text) {
 const log = document.getElementById('log');
 const el = document.createElement('div');
 el.className = `li ${role}`;
 el.innerHTML = `<div class="la">${role==='user'?'👤':'🤖'}</div><div class="bub">${text.slice(0,100)}${text.length>100?'…':''}</div>`;
 log.appendChild(el);
 log.scrollTop = log.scrollHeight;
 if (role === 'agent') _respText = '';
}
</script>
</body>
</html>
